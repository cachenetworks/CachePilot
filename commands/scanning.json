{
  "_meta": { "category": "scanning" },
  "scanning mode": {
    "type": "key", "key": "v",
    "response": [
      "Activating scanning mode.",
      "Scanner online.",
      "Switching to scan, Captain.",
      "Scan systems hot."
    ],
    "aliases": ["scan mode"]
  },
  "activate scanning": {
    "type": "mouse", "button": "left",
    "response": [
      "Scanning.",
      "Scan started, Captain.",
      "Pinging contacts.",
      "Sweeping sensors."
    ],
    "aliases": ["scan"]
  },
  "scanning ping": {
    "type": "hold", "key": "v", "duration": 0.8,
    "response": [
      "Scan ping out.",
      "Pinging, Captain.",
      "Wide sweep deployed.",
      "Active ping sent."
    ],
    "aliases": ["ping", "scan ping"]
  },
  "increase scanning angle": {
    "type": "scroll", "direction": "up", "amount": 3,
    "response": [
      "Widening scan angle.",
      "Scan cone expanding.",
      "Increasing scan arc, Captain.",
      "Wider sweep."
    ]
  },
  "decrease scanning angle": {
    "type": "scroll", "direction": "down", "amount": 3,
    "response": [
      "Narrowing scan angle.",
      "Scan cone tightening.",
      "Focusing the sweep, Captain.",
      "Tighter scan arc."
    ]
  },
  "increase ping angle": {
    "type": "unbound",
    "response": [
      "Increase ping angle is unbound.",
      "No default keybind, Captain.",
      "Ping angle increase not bound.",
      "Bind that in-game first."
    ]
  },
  "decrease ping angle": {
    "type": "unbound",
    "response": [
      "Decrease ping angle is unbound.",
      "No default keybind, Captain.",
      "Ping angle decrease not bound.",
      "Bind that in-game first."
    ]
  }
}
